generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobType {
  INTERNSHIP
  FULL_TIME
  PART_TIME
}

enum ApplicationStatus {
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
}

model Application {
  id            String              @id @default(uuid())
  companyName   String
  jobTitle      String
  jobType       JobType
  status        ApplicationStatus   @default(APPLIED)
  appliedDate   DateTime
  notes         String?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([status])
  @@index([companyName])
}